/* Responsive adjustments */
@media (max-width: 768px) {
  .host-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    padding-right: 45px;
  }
  
  .host-header h3 {
    font-size: 18px;
  }
  
  .close-btn {
    top: 10px;
    right: 10px;
    width: 28px;
    height: 28px;
    font-size: 16px;
  }
  
  .host-info-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 480px) {
  .host-info-grid {
    grid-template-columns: 1fr;
  }
}

/* Vulnerability Panel Updates */
.vuln-panel-container {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.vuln-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.vuln-item {
  padding: 12px;
  background: #0d1117;
  border-radius: 6px;
  margin-bottom: 10px;
  border-left: 4px solid;
  cursor: pointer;
  transition: all 0.2s;
}

.vuln-item:hover {
  background: #21262d;
  transform: translateX(5px);
}

.vuln-header {
  display: flex;
  gap: 10px;
  align-items: center;
  margin-bottom: 6px;
  flex-wrap: wrap;
}

.severity-badge {
  padding: 3px 8px;
  border-radius: 4px;
  font-size: 10px;
  font-weight: bold;
  color: white;
  text-transform: uppercase;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  white-space: nowrap;
}

.vuln-name {
  font-weight: 600;
  color: #f0f6fc;
  font-size: 13px;
}

.vuln-url {
  color: #58a6ff;
  font-size: 12px;
  margin-bottom: 4px;
  font-family: 'Fira Code', monospace;
}

.vuln-info {
  color: #8b949e;
  font-size: 12px;
  line-height: 1.5;
}

/* Modal updates for vulnerability details */
.host-detail-modal {
  max-width: 1000px;
  width: 90%;
}

.host-info-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15px;
  margin-bottom: 20px;
}

@media (max-width: 768px) {
  .host-info-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .vuln-header {
    flex-direction: column;
    align-items: flex-start;
  }
}

@media (max-width: 480px) {
  .host-info-grid {
    grid-template-columns: 1fr;
  }
}
/* Scan History Styles */
.scan-history-container {
  padding: 20px;
}

.scan-history-container .panel-body {
  max-height: none;
  overflow: visible;
}

.scan-history-container .data-table {
  font-size: 13px;
}

.scan-history-container .data-table th {
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.scan-history-container .data-table tr.selected {
  background: #21262d;
  border-left: 3px solid #58a6ff;
}

.scan-history-container input[type="checkbox"] {
  cursor: pointer;
  accent-color: #58a6ff;
}

/* Delete Confirmation Modal */
.host-detail-modal {
  max-width: 500px;
}

.host-detail-modal .host-header {
  justify-content: center;
  flex-direction: column;
  gap: 15px;
}

.host-detail-modal .host-header h3 {
  color: #ef4444;
  font-size: 24px;
}

/* Navigation Buttons */
nav button {
  transition: all 0.2s;
}

nav button:hover {
  background: #21262d;
  border-color: #58a6ff;
}

/* Progress Bar in Table */
.data-table td {
  vertical-align: middle;
}

/* Responsive History Table */
@media (max-width: 1200px) {
  .scan-history-container .data-table {
    font-size: 12px;
  }
  
  .scan-history-container .data-table th,
  .scan-history-container .data-table td {
    padding: 8px;
  }
}

@media (max-width: 768px) {
  .header {
    flex-direction: column;
    gap: 15px;
  }
  
  nav {
    width: 100%;
    justify-content: center;
  }
  
  .scan-form {
    width: 100%;
  }
  
  .target-input {
    width: 100%;
    min-width: auto;
  }
}