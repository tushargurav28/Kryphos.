class ReportConfig:
    """Configuration constants for report generation"""
    
    # Page Settings
    PAGE_SIZE = letter
    PAGE_WIDTH = letter[0]
    PAGE_HEIGHT = letter[1]
    MARGIN_TOP = 0.5 * inch
    MARGIN_BOTTOM = 0.5 * inch
    MARGIN_LEFT = 0.5 * inch
    MARGIN_RIGHT = 0.5 * inch
    
    # Font Sizes
    FONT_SIZE_TITLE = 24
    FONT_SIZE_HEADING_1 = 18
    FONT_SIZE_HEADING_2 = 14
    FONT_SIZE_HEADING_3 = 12
    FONT_SIZE_NORMAL = 10
    FONT_SIZE_SMALL = 8
    FONT_SIZE_TINY = 7
    
    # Table Settings
    TABLE_FONT_SIZE = 9
    TABLE_HEADER_FONT_SIZE = 10
    TABLE_CELL_PADDING = 6
    TABLE_BORDER_WIDTH = 0.5
    TABLE_BORDER_COLOR = HexColor('#bdc3c7')
    
    # Colors
    COLOR_PRIMARY = HexColor('#2c3e50')
    COLOR_SECONDARY = HexColor('#34495e')
    COLOR_ACCENT = HexColor('#3498db')
    COLOR_SUCCESS = HexColor('#27ae60')
    COLOR_WARNING = HexColor('#f39c12')
    COLOR_DANGER = HexColor('#e74c3c')
    COLOR_INFO = HexColor('#1abc9c')
    COLOR_LIGHT = HexColor('#ecf0f1')
    COLOR_DARK = HexColor('#2c3e50')
    COLOR_WHITE = HexColor('#ffffff')
    COLOR_GRAY = HexColor('#95a5a6')
    
    # Severity Colors
    SEVERITY_CRITICAL = HexColor('#c0392b')
    SEVERITY_HIGH = HexColor('#d35400')
    SEVERITY_MEDIUM = HexColor('#f39c12')
    SEVERITY_LOW = HexColor('#2980b9')
    SEVERITY_INFO = HexColor('#7f8c8d')
    
    # Risk Colors
    RISK_CRITICAL = HexColor('#c0392b')
    RISK_HIGH = HexColor('#e74c3c')
    RISK_MEDIUM = HexColor('#f39c12')
    RISK_LOW = HexColor('#27ae60')
    RISK_INFO = HexColor('#95a5a6')
    
    # Status Colors
    STATUS_COMPLETE = HexColor('#27ae60')
    STATUS_IN_PROGRESS = HexColor('#3498db')
    STATUS_PENDING = HexColor('#95a5a6')
    STATUS_FAILED = HexColor('#e74c3c')
    
    # Spacing
    SPACING_XS = 0.1 * inch
    SPACING_SM = 0.15 * inch
