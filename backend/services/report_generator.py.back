# CUSTOM STYLES
# =============================================================================

class ReportStyles:
    """Custom paragraph and table styles for professional reports"""
    
    def __init__(self):
        self.styles = getSampleStyleSheet()
        self._create_custom_styles()
    
    def _create_custom_styles(self):
        """Create all custom paragraph styles"""
        
        # Report Title
        self.styles.add(ParagraphStyle(
            name='ReportTitle',
            parent=self.styles['Heading1'],
            fontSize=ReportConfig.FONT_SIZE_TITLE,
            textColor=ReportConfig.COLOR_PRIMARY,
            spaceAfter=ReportConfig.SPACING_LG,
            alignment=TA_CENTER,
            fontName='Helvetica-Bold',
            leading=30
        ))
        
        # Section Headers
        self.styles.add(ParagraphStyle(
            name='SectionHeader',
            parent=self.styles['Heading2'],
            fontSize=ReportConfig.FONT_SIZE_HEADING_1,
            textColor=ReportConfig.COLOR_PRIMARY,
            spaceAfter=ReportConfig.SPACING_MD,
            spaceBefore=ReportConfig.SPACING_LG,
            fontName='Helvetica-Bold',
            leading=22,
            borderWidth=2,
            borderColor=ReportConfig.COLOR_ACCENT,
            borderPadding=8
        ))
        
        # Subsection Headers
        self.styles.add(ParagraphStyle(
            name='SubsectionHeader',
            parent=self.styles['Heading3'],
            fontSize=ReportConfig.FONT_SIZE_HEADING_2,
            textColor=ReportConfig.COLOR_SECONDARY,
            spaceAfter=ReportConfig.SPACING_SM,
            spaceBefore=ReportConfig.SPACING_MD,
            fontName='Helvetica-Bold',
            leading=16
        ))
        
        # Normal Text
        self.styles.add(ParagraphStyle(
            name='ReportNormal',
            parent=self.styles['Normal'],
            fontSize=ReportConfig.FONT_SIZE_NORMAL,
            textColor=ReportConfig.COLOR_DARK,
            spaceAfter=ReportConfig.SPACING_SM,
            leading=14,
            alignment=TA_JUSTIFY
        ))
        
        # Executive Summary
        self.styles.add(ParagraphStyle(
            name='ExecutiveSummary',
            parent=self.styles['Normal'],
            fontSize=ReportConfig.FONT_SIZE_NORMAL,
            textColor=ReportConfig.COLOR_DARK,
            spaceAfter=ReportConfig.SPACING_SM,
            leftIndent=ReportConfig.SPACING_MD,
            rightIndent=ReportConfig.SPACING_MD,
            leading=14
        ))
        
        # Alert Banners
        self.styles.add(ParagraphStyle(
            name='CriticalAlert',
            parent=self.styles['Normal'],
            fontSize=ReportConfig.FONT_SIZE_NORMAL,
            textColor=ReportConfig.COLOR_WHITE,
            spaceAfter=ReportConfig.SPACING_SM,
            fontName='Helvetica-Bold',
            backColor=ReportConfig.SEVERITY_CRITICAL,
            leading=14
        ))
        
        self.styles.add(ParagraphStyle(
            name='HighAlert',
            parent=self.styles['Normal'],
            fontSize=ReportConfig.FONT_SIZE_NORMAL,
            textColor=ReportConfig.COLOR_WHITE,
            spaceAfter=ReportConfig.SPACING_SM,
            fontName='Helvetica-Bold',
            backColor=ReportConfig.SEVERITY_HIGH,
            leading=14
        ))
        
        # Table Headers
        self.styles.add(ParagraphStyle(
            name='TableHeader',
            parent=self.styles['Normal'],
            fontSize=ReportConfig.TABLE_HEADER_FONT_SIZE,
            textColor=ReportConfig.COLOR_WHITE,
            fontName='Helvetica-Bold',
            alignment=TA_CENTER,
            leading=12
        ))
        
        # Table Cells
        self.styles.add(ParagraphStyle(
            name='TableCell',
            parent=self.styles['Normal'],
            fontSize=ReportConfig.TABLE_FONT_SIZE,
            textColor=ReportConfig.COLOR_DARK,
            alignment=TA_LEFT,
            leading=12,
            wordWrap=True
        ))
        
        # Footer
        self.styles.add(ParagraphStyle(
            name='ReportFooter',
            parent=self.styles['Normal'],
            fontSize=ReportConfig.FONT_SIZE_SMALL,
            textColor=ReportConfig.COLOR_GRAY,
            alignment=TA_CENTER,
            spaceBefore=ReportConfig.SPACING_SM
        ))
        
        # Code/Monospace
        self.styles.add(ParagraphStyle(
            name='CodeStyle',
            parent=self.styles['Normal'],
            fontSize=ReportConfig.FONT_SIZE_SMALL,
            textColor=ReportConfig.COLOR_DARK,
            fontName='Courier',
            leading=10,
            wordWrap=True
        ))
        
        # Key Findings
        self.styles.add(ParagraphStyle(
            name='KeyFinding',
            parent=self.styles['Normal'],
            fontSize=ReportConfig.FONT_SIZE_NORMAL,
            textColor=ReportConfig.COLOR_DARK,
            spaceAfter=ReportConfig.SPACING_XS,
            leftIndent=ReportConfig.SPACING_MD,
            leading=13
        ))
        
        # Vulnerability Name
        self.styles.add(ParagraphStyle(
            name='VulnName',
            parent=self.styles['Normal'],
            fontSize=ReportConfig.FONT_SIZE_NORMAL,
            textColor=ReportConfig.COLOR_DARK,
            fontName='Helvetica-Bold',
            leading=12
        ))
        
        # Vulnerability Description
        self.styles.add(ParagraphStyle(
            name='VulnDescription',
            parent=self.styles['Normal'],
            fontSize=ReportConfig.FONT_SIZE_NORMAL,
            textColor=ReportConfig.COLOR_DARK,
            spaceAfter=ReportConfig.SPACING_XS,
