    # Limits
    MAX_VULNS_PER_PAGE = 15
    MAX_HOSTS_PER_PAGE = 20
    MAX_PORTS_PER_PAGE = 30
    MAX_TECHNOLOGIES = 10
    MAX_REFERENCES = 5
    MAX_DESCRIPTION_LENGTH = 500
    MAX_REMEDIATION_LENGTH = 400


