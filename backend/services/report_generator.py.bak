# SECTION 6: DATA PROCESSORS
# =============================================================================

class VulnerabilityProcessor:
    """Process and organize vulnerability data."""

    def extract_vulnerabilities(self, vulnerabilities: List[Dict]) -> Dict[str, List[Dict]]:
        """Group vulnerabilities by severity."""

        grouped = {
            'critical': [],
            'high': [],
            'medium': [],
            'low': [],
            'info': []
        }

        for vuln in vulnerabilities:
            try:
                severity = vuln.get('info', {}).get('severity', 'info').lower()
                if severity in grouped:
                    grouped[severity].append(vuln)
            except Exception:
                grouped['info'].append(vuln)

        return grouped

    def count_by_severity(self, vulnerabilities: List[Dict]) -> Dict[str, int]:
        """Count vulnerabilities by severity."""

        counts = {'critical': 0, 'high': 0, 'medium': 0, 'low': 0, 'info': 0}

        for vuln in vulnerabilities:
            try:
                severity = vuln.get('info', {}).get('severity', 'info').lower()
                if severity in counts:
                    counts[severity] += 1
            except Exception:
                counts['info'] += 1

        return counts

    def extract_critical(self, vulnerabilities: List[Dict]) -> List[Dict]:
        return [v for v in vulnerabilities
                if v.get('info', {}).get('severity', '').lower() == 'critical']

    def extract_high(self, vulnerabilities: List[Dict]) -> List[Dict]:
        return [v for v in vulnerabilities
                if v.get('info', {}).get('severity', '').lower() == 'high']

    def extract_medium(self, vulnerabilities: List[Dict]) -> List[Dict]:
        return [v for v in vulnerabilities
                if v.get('info', {}).get('severity', '').lower() == 'medium']

    def extract_low(self, vulnerabilities: List[Dict]) -> List[Dict]:
        """Extract low-severity vulnerabilities."""
        return [v for v in vulnerabilities
                if v.get('info', {}).get('severity', '').lower() == 'low']

    def get_vuln_details(self, vuln: Dict) -> Dict[str, Any]:
        """Extract complete vulnerability details."""

        info = vuln.get('info', {})
        classification = info.get('classification', {})

        return {
            'name': info.get('name', 'Unknown'),
            'severity': info.get('severity', 'info').upper(),
            'description': info.get('description', 'No description available.'),
            'remediation': info.get('remediation', 'No remediation provided.'),
            'host': vuln.get('host', 'N/A'),
            'template_id': vuln.get('template-id', 'N/A'),
            'template_url': vuln.get('template-url', 'N/A'),
            'cve_id': classification.get('cve-id', None),
            'cvss_score': classification.get('cvss-metrics', None),
            'references': info.get('reference', []),
            'tags': info.get('tags', []),
            'matched_at': vuln.get('matched-at', 'N/A'),
            'extracted_results': vuln.get('extracted-results', []),
            'matcher_name': vuln.get('matcher-name', 'N/A')
        }

    def calculate_risk_score(self, vulnerabilities: List[Dict]) -> int:
        """Calculate overall risk score (0-100)."""

        if not vulnerabilities:
            return 100

        severity_weights = {
            'critical': 25,
            'high': 15,
            'medium': 8,
            'low': 2,
            'info': 0
        }

        score = 100
        counts = self.count_by_severity(vulnerabilities)

        for severity, weight in severity_weights.items():
            score -= counts.get(severity, 0) * weight

        return max(0, min(100, score))

    def get_risk_level(self, score: int) -> str:
        """Get risk level label from score."""
        if score >= 80:
            return 'Good'
        elif score >= 60:
            return 'Fair'
        elif score >= 40:
            return 'Needs Improvement'
        else:
            return 'Critical'


class DNSSSLProcessor:
    """Process DNS and SSL/TLS information."""

    def extract_dns_records(self, vulnerabilities: List[Dict]) -> Dict[str, Any]:
        """Extract DNS configuration from Nuclei results."""

        dns_info = {
            'nameservers': [],
            'mx_records': [],
            'spf': None,
            'dmarc': None,
            'dnssec': False,
            'ipv6': [],
            'caa': False,
            'txt_records': []
        }

        for vuln in vulnerabilities:
            try:
                template_id = vuln.get('template-id', '')
                extracted = vuln.get('extracted-results', [])

                if 'nameserver-fingerprint' in template_id:
                    dns_info['nameservers'] = [ns.rstrip('.') for ns in extracted]
                elif 'mx-fingerprint' in template_id:
                    dns_info['mx_records'] = extracted
                elif 'spf-record-detect' in template_id:
                    dns_info['spf'] = extracted[0] if extracted else None
                elif 'dmarc-detect' in template_id:
                    dns_info['dmarc'] = extracted[0] if extracted else None
                elif 'dnssec-detection' in template_id:
                    dns_info['dnssec'] = True
                elif 'aaaa-fingerprint' in template_id:
                    dns_info['ipv6'] = extracted
                elif 'caa-fingerprint' in template_id:
                    dns_info['caa'] = True
                elif 'txt-fingerprint' in template_id:
                    dns_info['txt_records'] = extracted
            except Exception:
                continue

        return dns_info

    def extract_ssl_info(self, vulnerabilities: List[Dict]) -> Dict[str, Any]:
        """Extract SSL/TLS configuration from Nuclei results."""

        ssl_info = {
            'issuer': None,
            'san': [],
            'wildcard': False,
            'tls_versions': [],
            'weak_ciphers': [],
            'deprecated_tls': []
        }

        for vuln in vulnerabilities:
            try:
                template_id = vuln.get('template-id', '')
                extracted = vuln.get('extracted-results', [])

                if 'ssl-issuer' in template_id:
                    ssl_info['issuer'] = extracted[0] if extracted else None
                elif 'ssl-dns-names' in template_id:
                    ssl_info['san'] = extracted
                elif 'wildcard-tls' in template_id:
                    ssl_info['wildcard'] = True
                elif 'tls-version' in template_id:
                    ssl_info['tls_versions'].extend(extracted)
                elif 'weak-cipher-suites' in template_id:
                    ssl_info['weak_ciphers'].extend(extracted)
                elif 'deprecated-tls' in template_id:
                    ssl_info['deprecated_tls'].extend(extracted)
            except Exception:
                continue

        ssl_info['tls_versions'] = list(set(ssl_info['tls_versions']))
        ssl_info['weak_ciphers'] = list(set(ssl_info['weak_ciphers']))
        ssl_info['deprecated_tls'] = list(set(ssl_info['deprecated_tls']))

        return ssl_info

    def get_dns_status_table(self, dns_info: Dict[str, Any]) -> List[List[str]]:
        """Create DNS status table data with proper status text."""

        return [
            ['Record Type', 'Value', 'Status'],
            ['NS Records',
             TextUtils.safe_text(', '.join(dns_info['nameservers'][:3]) if dns_info['nameservers'] else 'Not Found', 50),
             TextUtils.get_status_text('configured' if dns_info['nameservers'] else 'missing')],
            ['MX Records',
             TextUtils.safe_text(', '.join(dns_info['mx_records'][:3]) if dns_info['mx_records'] else 'Not Configured', 50),
             TextUtils.get_status_text('configured' if dns_info['mx_records'] else 'missing')],
            ['SPF Record',
             TextUtils.safe_text(dns_info['spf'] if dns_info['spf'] else 'Not Found', 50),
             TextUtils.get_status_text('configured' if dns_info['spf'] else 'missing')],
            ['DMARC Record',
             TextUtils.safe_text(dns_info['dmarc'] if dns_info['dmarc'] else 'Not Found', 50),
             TextUtils.get_status_text('configured' if dns_info['dmarc'] else 'missing')],
            ['DNSSEC',
             'Enabled' if dns_info['dnssec'] else 'Not Enabled',
             TextUtils.get_status_text('configured' if dns_info['dnssec'] else 'missing')],
            ['IPv6 (AAAA)',
             TextUtils.safe_text(', '.join(dns_info['ipv6'][:2]) if dns_info['ipv6'] else 'Not Found', 50),
             TextUtils.get_status_text('configured' if dns_info['ipv6'] else 'missing')],
        ]

    def get_ssl_status_table(self, ssl_info: Dict[str, Any]) -> List[List[str]]:
        """Create SSL status table data."""

        return [
            ['Property', 'Value', 'Status'],
            ['Certificate Issuer',
             ssl_info['issuer'] if ssl_info['issuer'] else 'Unknown', 'Info'],
            ['TLS Versions',
             '\n'.join(ssl_info['tls_versions']) if ssl_info['tls_versions'] else 'Not Detected',
             'Secure' if any('TLS 1.2' in v or 'TLS 1.3' in v for v in ssl_info['tls_versions']) else 'Review'],
            ['Weak Ciphers',
             ', '.join(ssl_info['weak_ciphers'][:3]) if ssl_info['weak_ciphers'] else 'None Detected',
             'Found' if ssl_info['weak_ciphers'] else 'None'],
            ['Deprecated TLS',
             ', '.join(ssl_info['deprecated_tls']) if ssl_info['deprecated_tls'] else 'None',
             'Found' if ssl_info['deprecated_tls'] else 'None'],
            ['Wildcard Certificate',
             'Yes' if ssl_info['wildcard'] else 'No',
             'Yes' if ssl_info['wildcard'] else 'No'],
            ['Subject Alternative Names',
             ', '.join(ssl_info['san'][:5]) if ssl_info['san'] else 'Not Found', 'Info'],
        ]


class NmapProcessor:
    """Process Nmap scan results."""

    def extract_open_ports(self, nmap_results: List[Dict]) -> List[Dict]:
        """Extract and process open ports from Nmap results."""

        open_ports = []

        for nmap in nmap_results:
            try:
                ip = nmap.get('ip', 'N/A')
                host = nmap.get('host', 'N/A')
                ports = nmap.get('open_ports', [])
                port_details = nmap.get('ports', [])

                for port in ports:
                    port_info = {
                        'ip': ip,
                        'host': host,
                        'port': port,
                        'protocol': 'tcp',
                        'service': 'unknown',
                        'version': 'unknown',
                        'state': 'open',
                        'risk': self._assess_port_risk(port)
                    }

                    for detail in port_details:
                        if str(detail.get('port', '')) == str(port):
                            port_info['protocol'] = detail.get('protocol', 'tcp')
                            port_info['service'] = detail.get('service', 'unknown')
                            port_info['version'] = detail.get('version', 'unknown')
                            break

                    open_ports.append(port_info)
            except Exception:
                continue

        return open_ports

    def _assess_port_risk(self, port: int) -> str:
        """Assess risk level for an open port."""
        high_risk_ports = [21, 22, 23, 25, 3306, 5432, 1433, 6379, 27017]
        medium_risk_ports = [80, 443, 8080, 8443, 3389, 5900]

        if port in high_risk_ports:
            return 'High'
        elif port in medium_risk_ports:
            return 'Medium'
        return 'Low'

    def extract_services(self, nmap_results: List[Dict]) -> List[str]:
        """Extract detected services from Nmap results."""

        services = []
        for nmap in nmap_results:
            try:
                for detail in nmap.get('ports', []):
                    service = detail.get('service', '')
                    if service and service not in services:
                        services.append(service)
            except Exception:
                continue

        return services

    def get_ports_table(self, open_ports: List[Dict]) -> List[List[str]]:
        """Create ports table data."""

        data = [['Host', 'IP Address', 'Port', 'Protocol', 'Service', 'Version', 'State', 'Risk']]

        for port_info in open_ports[:ReportConfig.MAX_PORTS_PER_PAGE]:
            data.append([
                TextUtils.safe_text(port_info['host'], 30),
                port_info['ip'],
                str(port_info['port']),
                port_info['protocol'],
                port_info['service'],
                TextUtils.safe_text(port_info['version'] if port_info['version'] else 'unknown', 30),
                port_info['state'],
                port_info['risk']
            ])

        return data


class TechnologyProcessor:
    """Process technology detection data."""

    def count_technologies(self, vulnerabilities: List[Dict]) -> List[str]:
        """Extract detected technologies."""

        techs = []
        for vuln in vulnerabilities:
            try:
                if ('tech-detect' in vuln.get('template-id', '')
                        or 'waf-detect' in vuln.get('template-id', '')):
                    matcher = vuln.get('matcher-name', '')
                    if matcher and matcher not in techs:
                        techs.append(matcher)
            except Exception:
                continue

        return techs[:ReportConfig.MAX_TECHNOLOGIES]

    def count_missing_headers(self, vulnerabilities: List[Dict]) -> List[str]:
        """Extract missing security headers."""

        headers = []
        for vuln in vulnerabilities:
            try:
                if 'http-missing-security-headers' in vuln.get('template-id', ''):
                    header_name = vuln.get('matcher-name', '').replace('-', ' ').title()
                    if header_name and header_name not in headers:
                        headers.append(header_name)
            except Exception:
                continue

        return headers


# =============================================================================
# SECTION 7: RISK CALCULATOR
# =============================================================================

class RiskCalculator:
    """Calculate and assess security risk scores."""

    def calculate_vulnerability_risk(self, vuln: Dict) -> int:
        """Calculate risk score for individual vulnerability."""

        severity_scores = {
            'critical': 100,
            'high': 75,
            'medium': 50,
            'low': 25,
            'info': 10
        }

        severity = vuln.get('info', {}).get('severity', 'info').lower()
        base_score = severity_scores.get(severity, 10)
        return min(100, int(base_score))

    def calculate_overall_risk(self, report_data: Dict[str, Any]) -> Dict[str, Any]:
        """Calculate overall risk for entire assessment."""

        vulnerabilities = report_data.get('vulnerabilities', [])

        if not vulnerabilities:
            return {
                'score': 0,
                'level': 'Low',
                'summary': 'No vulnerabilities detected'
            }

        vuln_processor = VulnerabilityProcessor()
        score = vuln_processor.calculate_risk_score(vulnerabilities)
        level = vuln_processor.get_risk_level(score)
        severity_counts = vuln_processor.count_by_severity(vulnerabilities)

        summary_parts = []
        if severity_counts['critical'] > 0:
            summary_parts.append(f"{severity_counts['critical']} critical")
        if severity_counts['high'] > 0:
            summary_parts.append(f"{severity_counts['high']} high")
        if severity_counts['medium'] > 0:
            summary_parts.append(f"{severity_counts['medium']} medium")

        summary = f"Total {len(vulnerabilities)} vulnerabilities"
        if summary_parts:
            summary += f" ({', '.join(summary_parts)})"

        return {
            'score': score,
            'level': level,
            'summary': summary,
            'severity_counts': severity_counts,
            'total_vulnerabilities': len(vulnerabilities)
        }

    def generate_risk_matrix(self, report_data: Dict[str, Any]) -> List[List[str]]:
        """Generate risk matrix data for visualization."""

        vuln_processor = VulnerabilityProcessor()
        severity_counts = vuln_processor.count_by_severity(
            report_data.get('vulnerabilities', [])
        )
        total = max(1, sum(severity_counts.values()))

        return [
            ['Severity', 'Count', 'Percentage', 'Risk Level'],
            ['CRITICAL', str(severity_counts['critical']),
             f"{(severity_counts['critical'] / total * 100):.1f}%", 'Critical'],
            ['HIGH', str(severity_counts['high']),
             f"{(severity_counts['high'] / total * 100):.1f}%", 'High'],
            ['MEDIUM', str(severity_counts['medium']),
             f"{(severity_counts['medium'] / total * 100):.1f}%", 'Medium'],
            ['LOW', str(severity_counts['low']),
             f"{(severity_counts['low'] / total * 100):.1f}%", 'Low'],
            ['INFO', str(severity_counts['info']),
             f"{(severity_counts['info'] / total * 100):.1f}%", 'Informational'],
        ]


# =============================================================================
# SECTION 8: RECOMMENDATION ENGINE
# =============================================================================

class RecommendationEngine:
    """Generate security recommendations based on findings."""

    def __init__(self):
        self.recommendation_templates = self._load_templates()

    def _load_templates(self) -> Dict[str, Dict]:
        return {
            'missing_headers': {
                'title': 'Implement Security Headers',
                'description': 'Add missing HTTP security headers to protect against common attacks',
                'effort': 'Low',
                'impact': 'Medium',
                'priority': 'High',
                'actions': [
                    'Add Content-Security-Policy (CSP) header',
                    'Add X-Frame-Options header',
                    'Add X-Content-Type-Options header',
                    'Add Strict-Transport-Security (HSTS) header',
                    'Add Referrer-Policy header'
                ]
            },
            'weak_tls': {
                'title': 'Update TLS Configuration',
                'description': 'Disable deprecated TLS versions and weak cipher suites',
                'effort': 'Medium',
                'impact': 'High',
                'priority': 'High',
                'actions': [
                    'Disable TLS 1.0 and TLS 1.1',
                    'Enable TLS 1.2 and TLS 1.3 only',
                    'Disable weak cipher suites',
                    'Enable perfect forward secrecy'
                ]
            }
        }

    def generate_recommendations(self, report_data: Dict[str, Any]) -> List[Dict]:
        """Generate recommendations based on report data."""

        recommendations = []

        if report_data['summary'].get('missing_headers'):
            rec = self.recommendation_templates['missing_headers'].copy()
            rec['count'] = len(report_data['summary']['missing_headers'])
            rec['specific_headers'] = report_data['summary']['missing_headers']
            recommendations.append(rec)

        ssl_info = report_data['summary'].get('ssl_info', {})
        if ssl_info.get('deprecated_tls') or ssl_info.get('weak_ciphers'):
            rec = self.recommendation_templates['weak_tls'].copy()
            rec['deprecated_versions'] = ssl_info.get('deprecated_tls', [])
            rec['weak_ciphers'] = ssl_info.get('weak_ciphers', [])
            recommendations.append(rec)

        return recommendations[:ReportConfig.MAX_RECOMMENDATIONS]


