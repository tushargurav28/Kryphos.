class TableBuilder:
    """Helper class for building professional tables."""

    def __init__(self):
        self.styles = ReportStyles()

    def create_table(
        self,
        data: List[List[str]],
        col_widths: Optional[List[float]] = None,
        header_color=None,
        row_colors: Optional[List] = None,
        font_size: int = ReportConfig.TABLE_FONT_SIZE,
        header_font_size: int = ReportConfig.TABLE_HEADER_FONT_SIZE,
        word_wrap: bool = True,
        vertical_align: str = 'TOP'
    ) -> Optional[Table]:
        """Create a professional table with styling."""

        if not REPORTLAB_AVAILABLE:
            return None

        if header_color is None:
            header_color = ReportConfig.COLOR_PRIMARY

        if not data:
            return Table(
                [['No data available']],
                colWidths=[ReportConfig.PAGE_WIDTH - 2 * inch]
            )

        table = Table(data, colWidths=col_widths)

        style_commands = [
            ('GRID', (0, 0), (-1, -1), ReportConfig.TABLE_BORDER_WIDTH, ReportConfig.TABLE_BORDER_COLOR),
            ('BACKGROUND', (0, 0), (-1, 0), header_color),
            ('TEXTCOLOR', (0, 0), (-1, 0), ReportConfig.COLOR_WHITE),
            ('FONTNAME', (0, 0), (-1, 0), 'Helvetica-Bold'),
            ('FONTSIZE', (0, 0), (-1, 0), header_font_size),
            ('BOTTOMPADDING', (0, 0), (-1, 0), ReportConfig.TABLE_CELL_PADDING),
            ('TOPPADDING', (0, 0), (-1, 0), ReportConfig.TABLE_CELL_PADDING),
            ('FONTNAME', (0, 1), (-1, -1), 'Helvetica'),
            ('FONTSIZE', (0, 1), (-1, -1), font_size),
            ('BOTTOMPADDING', (0, 1), (-1, -1), ReportConfig.TABLE_CELL_PADDING - 2),
            ('TOPPADDING', (0, 1), (-1, -1), ReportConfig.TABLE_CELL_PADDING - 2),
            ('VALIGN', (0, 0), (-1, -1), vertical_align),
        ]

        if row_colors:
            for row_idx, color in enumerate(row_colors, 1):
                style_commands.append(('BACKGROUND', (0, row_idx), (-1, row_idx), color))
        else:
            style_commands.append(('ROWBACKGROUNDS', (0, 1), (-1, -1), [
                ReportConfig.COLOR_WHITE,
                HexColor('#f8f9fa')
            ]))

        if word_wrap:
            style_commands.append(('WORDWRAP', (0, 1), (-1, -1), 'ON'))

        table.setStyle(TableStyle(style_commands))
        return table

    def create_kpi_table(self, data: List[List[str]]) -> Optional[Table]:
        """Create a KPI metrics table."""

        if not REPORTLAB_AVAILABLE:
            return None

        table = Table(data, colWidths=[2 * inch, 1 * inch, 1.5 * inch])

        style_commands = [
            ('GRID', (0, 0), (-1, -1), 1, ReportConfig.TABLE_BORDER_COLOR),
            ('BACKGROUND', (0, 0), (-1, 0), ReportConfig.COLOR_PRIMARY),
            ('TEXTCOLOR', (0, 0), (-1, 0), ReportConfig.COLOR_WHITE),
            ('ALIGN', (0, 0), (-1, -1), 'CENTER'),
            ('FONTNAME', (0, 0), (-1, 0), 'Helvetica-Bold'),
            ('FONTSIZE', (0, 0), (-1, 0), 10),
            ('BOTTOMPADDING', (0, 0), (-1, 0), 8),
            ('TOPPADDING', (0, 0), (-1, 0), 8),
            ('FONTNAME', (0, 1), (-1, -1), 'Helvetica'),
            ('FONTSIZE', (0, 1), (-1, -1), 9),
            ('ROWBACKGROUNDS', (0, 1), (-1, -1), [
                ReportConfig.COLOR_WHITE,
                HexColor('#f8f9fa')
            ]),
            ('VALIGN', (0, 0), (-1, -1), 'MIDDLE'),
        ]

        table.setStyle(TableStyle(style_commands))
        return table

    def create_risk_table(self, data: List[List[str]], severity_counts: Dict[str, int]) -> Optional[Table]:
        """Create a risk distribution table with color coding."""

        if not REPORTLAB_AVAILABLE:
            return None

        table = Table(data, colWidths=[1.5 * inch, 0.8 * inch, 1 * inch, 2 * inch])

        severity_colors = {
            'CRITICAL': ReportConfig.SEVERITY_CRITICAL,
            'HIGH': ReportConfig.SEVERITY_HIGH,
            'MEDIUM': ReportConfig.SEVERITY_MEDIUM,
            'LOW': ReportConfig.SEVERITY_LOW,
            'INFO': ReportConfig.SEVERITY_INFO
        }

        style_commands = [
            ('GRID', (0, 0), (-1, -1), 1, ReportConfig.TABLE_BORDER_COLOR),
            ('BACKGROUND', (0, 0), (-1, 0), ReportConfig.COLOR_SECONDARY),
            ('TEXTCOLOR', (0, 0), (-1, 0), ReportConfig.COLOR_WHITE),
            ('ALIGN', (0, 0), (-1, -1), 'CENTER'),
            ('FONTNAME', (0, 0), (-1, 0), 'Helvetica-Bold'),
            ('FONTSIZE', (0, 0), (-1, 0), 9),
            ('BOTTOMPADDING', (0, 0), (-1, 0), 6),
            ('TOPPADDING', (0, 0), (-1, 0), 6),
            ('FONTNAME', (0, 1), (-1, -1), 'Helvetica'),
            ('FONTSIZE', (0, 1), (-1, -1), 8),
            ('ROWBACKGROUNDS', (0, 1), (-1, -1), [
                ReportConfig.COLOR_WHITE,
                HexColor('#f8f9fa')
            ]),
            ('VALIGN', (0, 0), (-1, -1), 'MIDDLE'),
        ]

        for row_idx, severity in enumerate(['CRITICAL', 'HIGH', 'MEDIUM', 'LOW', 'INFO'], 1):
            if severity_counts.get(severity.lower(), 0) > 0:
                style_commands.append((
                    'BACKGROUND', (0, row_idx), (0, row_idx),
                    severity_colors.get(severity, ReportConfig.COLOR_GRAY)
                ))
                style_commands.append((
                    'TEXTCOLOR', (0, row_idx), (0, row_idx),
                    ReportConfig.COLOR_WHITE
                ))

        table.setStyle(TableStyle(style_commands))
        return table

    def create_dns_status_table(self, dns_info: Dict[str, Any]) -> Optional[Table]:
        """Create DNS status table with proper status text."""

        if not REPORTLAB_AVAILABLE:
            return None

        data = [
            ['Record Type', 'Value', 'Status'],
            ['NS Records',
             TextUtils.safe_text(', '.join(dns_info.get('nameservers', [])[:3]) or 'Not Found', 50),
             TextUtils.get_status_text('configured' if dns_info.get('nameservers') else 'missing')],
            ['MX Records',
             TextUtils.safe_text(', '.join(dns_info.get('mx_records', [])[:3]) or 'Not Configured', 50),
             TextUtils.get_status_text('configured' if dns_info.get('mx_records') else 'missing')],
            ['SPF Record',
             TextUtils.safe_text(dns_info.get('spf') or 'Not Found', 50),
             TextUtils.get_status_text('configured' if dns_info.get('spf') else 'missing')],
            ['DMARC Record',
             TextUtils.safe_text(dns_info.get('dmarc') or 'Not Found', 50),
             TextUtils.get_status_text('configured' if dns_info.get('dmarc') else 'missing')],
            ['DNSSEC',
             'Enabled' if dns_info.get('dnssec') else 'Not Enabled',
             TextUtils.get_status_text('configured' if dns_info.get('dnssec') else 'missing')],
            ['IPv6 (AAAA)',
             TextUtils.safe_text(', '.join(dns_info.get('ipv6', [])[:2]) or 'Not Found', 50),
             TextUtils.get_status_text('configured' if dns_info.get('ipv6') else 'missing')],
        ]

        table = Table(data, colWidths=[1.2 * inch, 4 * inch, 1.2 * inch])

        style_commands = [
            ('GRID', (0, 0), (-1, -1), 1, ReportConfig.TABLE_BORDER_COLOR),
            ('BACKGROUND', (0, 0), (-1, 0), ReportConfig.COLOR_SUCCESS),
            ('TEXTCOLOR', (0, 0), (-1, 0), ReportConfig.COLOR_WHITE),
            ('ALIGN', (0, 0), (-1, -1), 'LEFT'),
            ('FONTNAME', (0, 0), (-1, 0), 'Helvetica-Bold'),
            ('FONTSIZE', (0, 0), (-1, 0), 9),
            ('BOTTOMPADDING', (0, 0), (-1, 0), 6),
            ('TOPPADDING', (0, 0), (-1, 0), 6),
            ('FONTNAME', (0, 1), (-1, -1), 'Helvetica'),
            ('FONTSIZE', (0, 1), (-1, -1), 8),
            ('ROWBACKGROUNDS', (0, 1), (-1, -1), [
                ReportConfig.COLOR_WHITE,
                HexColor('#f8f9fa')
            ]),
            ('VALIGN', (0, 0), (-1, -1), 'MIDDLE'),
            ('WORDWRAP', (1, 1), (1, -1), 'ON'),
        ]

        for row_idx in range(1, len(data)):
            status = data[row_idx][2]
            if status == 'Missing':
                style_commands.append(('BACKGROUND', (2, row_idx), (2, row_idx), ReportConfig.COLOR_DANGER))
                style_commands.append(('TEXTCOLOR', (2, row_idx), (2, row_idx), ReportConfig.COLOR_WHITE))
            elif status in ('Configured', 'Enabled'):
                style_commands.append(('BACKGROUND', (2, row_idx), (2, row_idx), ReportConfig.COLOR_SUCCESS))
                style_commands.append(('TEXTCOLOR', (2, row_idx), (2, row_idx), ReportConfig.COLOR_WHITE))
            else:
                style_commands.append(('BACKGROUND', (2, row_idx), (2, row_idx), ReportConfig.COLOR_WARNING))
                style_commands.append(('TEXTCOLOR', (2, row_idx), (2, row_idx), ReportConfig.COLOR_WHITE))

        table.setStyle(TableStyle(style_commands))
        return table

    def create_summary_table(self, data: List[List[str]]) -> Optional[Table]:
        """Create a summary table with minimal styling."""

        if not REPORTLAB_AVAILABLE:
            return None

        table = Table(data, colWidths=[2 * inch, 4 * inch])

        style_commands = [
            ('GRID', (0, 0), (-1, -1), 0.5, ReportConfig.TABLE_BORDER_COLOR),
            ('BACKGROUND', (0, 0), (0, -1), ReportConfig.COLOR_LIGHT),
            ('FONTNAME', (0, 0), (-1, -1), 'Helvetica'),
            ('FONTSIZE', (0, 0), (-1, -1), 9),
            ('BOTTOMPADDING', (0, 0), (-1, -1), 6),
            ('TOPPADDING', (0, 0), (-1, -1), 6),
            ('VALIGN', (0, 0), (-1, -1), 'TOP'),
        ]

        table.setStyle(TableStyle(style_commands))
        return table


