# SECTION 9: COMPLIANCE CHECKER
# =============================================================================

class ComplianceChecker:
    """Check compliance with security standards."""

    def check_compliance(self, report_data: Dict[str, Any],
                         standards: Optional[List[str]] = None) -> Dict[str, Any]:
        if standards is None:
            standards = ['OWASP Top 10']

        return {
            'standards_checked': standards,
            'results': {},
            'overall_compliance': 'Good'
        }


# =============================================================================
# SECTION 10: CHART GENERATOR
# =============================================================================

class ChartGenerator:
    """Generate charts and visualizations for reports."""

    def create_severity_pie_chart(self, severity_counts: Dict[str, int]) -> Optional[Any]:
        """Create pie chart for severity distribution."""

        if not REPORTLAB_AVAILABLE:
            return None

        try:
            drawing = Drawing(width=200, height=200)

            pie = Pie()
            pie.x = 50
            pie.y = 50
            pie.width = 100
            pie.height = 100

            data = []
            colors_list = []

            severity_order = ['critical', 'high', 'medium', 'low', 'info']
            severity_colors = [
                HexColor('#c0392b'),
                HexColor('#d35400'),
                HexColor('#f39c12'),
                HexColor('#2980b9'),
                HexColor('#7f8c8d')
            ]

            for idx, severity in enumerate(severity_order):
                count = severity_counts.get(severity, 0)
                if count > 0:
                    data.append(count)
                    colors_list.append(severity_colors[idx])

            if data:
                pie.data = data
                pie.slices.strokeWidth = 0.5
                for i, color in enumerate(colors_list):
                    pie.slices[i].fillColor = color
                drawing.add(pie)

            return drawing
        except Exception as e:
            print(f"Warning: Could not create pie chart: {e}")
            return None


# =============================================================================
# SECTION 11: MAIN REPORT GENERATOR CLASS
# =============================================================================

class ReportGenerator:
    """
    Main report generator class that coordinates all components
    to generate professional security reports in multiple formats.
    """

    def __init__(self):
        self.styles = ReportStyles()
        self.table_builder = TableBuilder()
        self.vuln_processor = VulnerabilityProcessor()
        self.dns_ssl_processor = DNSSSLProcessor()
        self.nmap_processor = NmapProcessor()
        self.tech_processor = TechnologyProcessor()
        self.risk_calculator = RiskCalculator()
        self.recommendation_engine = RecommendationEngine()
        self.compliance_checker = ComplianceChecker()
        self.chart_generator = ChartGenerator()
        self.config = ReportConfig()
        self.logger = LogUtils.get_logger()

    async def generate_report_data(self, db, scan_id: str) -> Optional[Dict[str, Any]]:
        """Gather and process all scan data for report generation."""
        try:
            self.logger.log_info(f"Generating report data for scan: {scan_id}")

            scan = await db.get_scan(scan_id)
            if not scan:
                self.logger.log_warning(f"Scan {scan_id} not found")
                return None

            self.logger.log_info(f"Scan found: {scan['target']}")

            all_results = await db.get_results(scan_id)
            self.logger.log_info(f"Retrieved {len(all_results)} results from database")

            report_data = {
                'scan_info': scan,
                'subdomains': [],
                'live_hosts': [],
                'wayback_urls': [],
                'vulnerabilities': [],
                'nmap_results': [],
                'katana_endpoints': [],
                'summary': {}
            }

            seen_hosts = set()
            seen_vulns = set()

            for result in all_results:
                try:
                    phase = result['phase']
                    data = result['data']
                    if isinstance(data, str):
                        try:
                            data = json.loads(data)
                        except Exception:
                            continue

                    if phase == 'subdomain':
                        report_data['subdomains'].append(data)
                    elif phase == 'httpx':
                        host_key = f"{data.get('url', '')}-{data.get('ip', '')}"
                        if host_key not in seen_hosts:
                            seen_hosts.add(host_key)
                            report_data['live_hosts'].append(data)
                    elif phase == 'wayback':
                        report_data['wayback_urls'].append(data)
                    elif phase == 'vulnerability':
                        vuln_key = (f"{data.get('template-id', '')}-"
                                    f"{data.get('host', '')}-"
                                    f"{data.get('matcher-name', '')}")
                        if vuln_key not in seen_vulns:
                            seen_vulns.add(vuln_key)
                            report_data['vulnerabilities'].append(data)
                    elif phase == 'nmap':
                        report_data['nmap_results'].append(data)
                    elif phase == 'katana':
                        report_data['katana_endpoints'].append(data)
                except Exception as e:
                    self.logger.log_error(f"Error processing result: {e}")
                    continue

            report_data['summary'] = self._generate_summary(report_data)

            self.logger.log_info("Report data generated successfully")
            self.logger.log_info(f"   - Subdomains: {report_data['summary']['total_subdomains']}")
            self.logger.log_info(f"   - Live Hosts: {report_data['summary']['total_live_hosts']}")
            self.logger.log_info(f"   - Vulnerabilities: {report_data['summary']['total_vulnerabilities']}")
            self.logger.log_info(f"   - Overall Risk: {report_data['summary']['overall_risk']}")

            return report_data

        except Exception as e:
            self.logger.log_exception(f"Error generating report: {e}")
            return None

    def _generate_summary(self, report_data: Dict[str, Any]) -> Dict[str, Any]:
        """Generate comprehensive report summary."""

        # FIX BUG 3: Added 'low_vulns' to the summary dict.
        # Previously, `_build_vulnerabilities_section` accessed
        # `report_data['summary']['low_vulns']` which always raised a KeyError.
        summary = {
            'total_subdomains': len(report_data['subdomains']),
            'total_live_hosts': len(report_data['live_hosts']),
            'total_vulnerabilities': len(report_data['vulnerabilities']),
            'total_nmap_scans': len(report_data['nmap_results']),
            'total_endpoints': len(report_data['katana_endpoints']),
            'vulnerability_by_severity': self.vuln_processor.count_by_severity(
                report_data['vulnerabilities']
            ),
            'missing_headers': self.tech_processor.count_missing_headers(
                report_data['vulnerabilities']
            ),
            'technologies_detected': self.tech_processor.count_technologies(
                report_data['vulnerabilities']
            ),
            'dns_records': self.dns_ssl_processor.extract_dns_records(
                report_data['vulnerabilities']
            ),
            'ssl_info': self.dns_ssl_processor.extract_ssl_info(
                report_data['vulnerabilities']
            ),
            'open_ports': self.nmap_processor.extract_open_ports(
                report_data['nmap_results']
            ),
            'services_detected': self.nmap_processor.extract_services(
                report_data['nmap_results']
            ),
            'critical_vulns': self.vuln_processor.extract_critical(
                report_data['vulnerabilities']
            ),
            'high_vulns': self.vuln_processor.extract_high(
                report_data['vulnerabilities']
            ),
            'medium_vulns': self.vuln_processor.extract_medium(
                report_data['vulnerabilities']
            ),
            # FIX BUG 3: low_vulns was missing — added here
            'low_vulns': self.vuln_processor.extract_low(
                report_data['vulnerabilities']
            ),
            'has_critical': False,
            'has_high': False,
            'has_medium': False,
            'overall_risk': 'Low',
            'security_score': 100,
            'risk_level': 'Good'
        }

        if summary['vulnerability_by_severity']['critical'] > 0:
            summary['has_critical'] = True
            summary['overall_risk'] = 'Critical'
        elif summary['vulnerability_by_severity']['high'] > 0:
            summary['has_high'] = True
            summary['overall_risk'] = 'High'
        elif summary['vulnerability_by_severity']['medium'] > 0:
            summary['has_medium'] = True
            summary['overall_risk'] = 'Medium'

        summary['security_score'] = self.vuln_processor.calculate_risk_score(
            report_data['vulnerabilities']
        )
        summary['risk_level'] = self.vuln_processor.get_risk_level(
            summary['security_score']
        )

        return summary

    def generate_pdf(self, report_data: Dict[str, Any],
                     options: Optional[Dict] = None) -> bytes:
        """Generate professional PDF report with complete information."""
        try:
            self.logger.log_info("Generating PDF report...")

            if options is None:
                options = ReportConfig.DEFAULT_EXPORT_OPTIONS

            if not REPORTLAB_AVAILABLE:
                self.logger.log_error("ReportLab not available")
                raise ImportError("ReportLab not available. Install with: pip install reportlab")

            buffer = io.BytesIO()

            doc = SimpleDocTemplate(
                buffer,
                pagesize=self.config.PAGE_SIZE,
                rightMargin=self.config.MARGIN_RIGHT,
                leftMargin=self.config.MARGIN_LEFT,
                topMargin=self.config.MARGIN_TOP,
                bottomMargin=self.config.MARGIN_BOTTOM,
                title=f"Security Report - {report_data['scan_info']['target']}"
            )

            elements = []

            elements.extend(self._build_cover_page(report_data))
            elements.append(Spacer(1, self.config.SPACING_LG))
            elements.extend(self._build_executive_summary(report_data))
            elements.append(PageBreak())
            elements.extend(self._build_vulnerabilities_section(report_data))
            elements.append(PageBreak())
            elements.extend(self._build_assets_section(report_data))
            elements.append(PageBreak())
            elements.extend(self._build_nmap_section(report_data))
            elements.append(PageBreak())
            elements.extend(self._build_dns_ssl_section(report_data))
            elements.append(PageBreak())

            if options.get('include_recommendations', True):
                elements.extend(self._build_recommendations_section(report_data))
                elements.append(PageBreak())

            elements.extend(self._build_footer(report_data))

            doc.build(elements)
            buffer.seek(0)

            self.logger.log_info("PDF generated successfully")
            return buffer.getvalue()

        except Exception as e:
            self.logger.log_exception(f"PDF generation failed: {e}")
            raise

    def _build_cover_page(self, report_data: Dict[str, Any]) -> List:
        """Build cover page elements."""

        elements = []

        elements.append(Spacer(1, 0.5 * inch))

        if report_data['summary']['has_critical']:
            alert_style = self.styles.get_style('CriticalAlert')
            if alert_style:
                elements.append(
                    Paragraph("CRITICAL SECURITY RISK DETECTED - IMMEDIATE ACTION REQUIRED",
                              alert_style)
                )
                elements.append(Spacer(1, self.config.SPACING_SM))
        elif report_data['summary']['has_high']:
            alert_style = self.styles.get_style('HighAlert')
            if alert_style:
                elements.append(
                    Paragraph("HIGH SECURITY RISK DETECTED - URGENT ATTENTION REQUIRED",
                              alert_style)
                )
                elements.append(Spacer(1, self.config.SPACING_SM))

        title_style = self.styles.get_style('ReportTitle')
        if title_style:
            elements.append(Paragraph("SECURITY RECONNAISSANCE REPORT", title_style))
            elements.append(Spacer(1, self.config.SPACING_MD))

        overall_risk = report_data['summary']['overall_risk']
        risk_bg = (
            self.config.SEVERITY_CRITICAL if overall_risk == 'Critical'
            else self.config.SEVERITY_HIGH if overall_risk == 'High'
            else self.config.SEVERITY_MEDIUM
        )

        info_data = [
            ['Target:', TextUtils.safe_text(report_data['scan_info']['target'], 200)],
            ['Scan ID:', report_data['scan_info']['id']],
            ['Scan Date:', report_data['scan_info']['started_at'][:10]
             if report_data['scan_info'].get('started_at') else 'N/A'],
            ['Status:', report_data['scan_info']['status'].upper()],
            ['Risk Level:', overall_risk.upper()],
            ['Report Generated:', datetime.now().strftime('%Y-%m-%d %H:%M')]
        ]

        info_table = Table(info_data, colWidths=[1.2 * inch, 4 * inch])
        info_table.setStyle(TableStyle([
            ('ALIGN', (0, 0), (-1, -1), 'LEFT'),
            ('FONTNAME', (0, 0), (0, -1), 'Helvetica-Bold'),
            ('FONTNAME', (1, 0), (1, -1), 'Helvetica'),
            ('FONTSIZE', (0, 0), (-1, -1), 11),
            ('BOTTOMPADDING', (0, 0), (-1, -1), 8),
            ('TOPPADDING', (0, 0), (-1, -1), 8),
            ('GRID', (0, 0), (-1, -1), 1, self.config.COLOR_GRAY),
            ('BACKGROUND', (0, 0), (0, -1), self.config.COLOR_LIGHT),
            ('BACKGROUND', (1, 4), (1, 4), risk_bg),
            ('TEXTCOLOR', (1, 4), (1, 4), self.config.COLOR_WHITE),
            ('VALIGN', (0, 0), (-1, -1), 'MIDDLE'),
            ('WORDWRAP', (1, 0), (1, -1), 'ON'),
        ]))
        elements.append(info_table)
        elements.append(Spacer(1, self.config.SPACING_MD))

        classification_style = self.styles.get_style('Classification')
        if classification_style:
            elements.append(Paragraph("CONFIDENTIAL - INTERNAL USE ONLY", classification_style))

        return elements

    def _build_executive_summary(self, report_data: Dict[str, Any]) -> List:
        """Build executive summary section."""

        elements = []

        header_style = self.styles.get_style('SectionHeader')
        if header_style:
            elements.append(Paragraph("EXECUTIVE SUMMARY", header_style))
            elements.append(Spacer(1, self.config.SPACING_SM))

        overview_text = (
            f"This security reconnaissance report provides a comprehensive assessment "
            f"of the target domain {report_data['scan_info']['target']}. The assessment "
            f"included subdomain enumeration, live host discovery, vulnerability scanning, "
            f"DNS analysis, and port scanning."
        )
        overview_style = self.styles.get_style('ExecutiveSummary')
        if overview_style:
            elements.append(Paragraph(overview_text, overview_style))
            elements.append(Spacer(1, self.config.SPACING_SM))

        subheader_style = self.styles.get_style('SubsectionHeader')
        if subheader_style:
            elements.append(Paragraph("Key Metrics", subheader_style))
            elements.append(Spacer(1, self.config.SPACING_XS))

        sev = report_data['summary']['vulnerability_by_severity']
        metrics_data = [
            ['Metric', 'Value', 'Status'],
            ['Total Assets Discovered',
             str(report_data['summary']['total_subdomains']), 'Complete'],
            ['Live Hosts Identified',
             str(report_data['summary']['total_live_hosts']), 'Verified'],
            ['Total Vulnerabilities',
             str(report_data['summary']['total_vulnerabilities']), 'Review Required'],
            ['Critical Issues', str(sev['critical']),
             'None' if sev['critical'] == 0 else 'Action Required'],
            ['High Risk Issues', str(sev['high']),
             'None' if sev['high'] == 0 else 'Urgent'],
            ['Medium Risk Issues', str(sev['medium']),
             'None' if sev['medium'] == 0 else 'Review'],
            ['Low Risk Issues', str(sev['low']), 'Minor'],
            ['Informational', str(sev['info']), 'Awareness'],
        ]

        metrics_table = self.table_builder.create_kpi_table(metrics_data)
        if metrics_table:
            elements.append(metrics_table)
            elements.append(Spacer(1, self.config.SPACING_SM))

        if subheader_style:
            elements.append(Paragraph("Risk Distribution", subheader_style))
            elements.append(Spacer(1, self.config.SPACING_XS))

        risk_matrix = self.risk_calculator.generate_risk_matrix(report_data)
        risk_table = self.table_builder.create_risk_table(
            risk_matrix, report_data['summary']['vulnerability_by_severity']
        )
        if risk_table:
            elements.append(risk_table)
            elements.append(Spacer(1, self.config.SPACING_SM))

        if subheader_style:
            elements.append(Paragraph("Key Findings", subheader_style))
            elements.append(Spacer(1, self.config.SPACING_XS))

        key_findings = self._generate_key_findings(report_data)
        finding_style = self.styles.get_style('KeyFinding')
        for idx, finding in enumerate(key_findings[:6], 1):
            if finding_style:
                elements.append(Paragraph(f"{idx}. {finding}", finding_style))

        return elements

    def _generate_key_findings(self, report_data: Dict[str, Any]) -> List[str]:
        """Generate key findings list."""

        findings = []

        for vuln in report_data['summary']['critical_vulns'][:2]:
            name = TextUtils.safe_text(vuln.get('info', {}).get('name', 'Unknown'), 100)
            host = TextUtils.safe_text(vuln.get('host', 'N/A'), 50)
            findings.append(f"[CRITICAL] {name} - {host}")

        for vuln in report_data['summary']['high_vulns'][:2]:
            name = TextUtils.safe_text(vuln.get('info', {}).get('name', 'Unknown'), 100)
            host = TextUtils.safe_text(vuln.get('host', 'N/A'), 50)
            findings.append(f"[HIGH] {name} - {host}")

        for vuln in report_data['summary']['medium_vulns'][:2]:
            name = TextUtils.safe_text(vuln.get('info', {}).get('name', 'Unknown'), 100)
            host = TextUtils.safe_text(vuln.get('host', 'N/A'), 50)
            findings.append(f"[MEDIUM] {name} - {host}")

        if report_data['summary']['missing_headers']:
            findings.append(
                f"Missing Security Headers - "
                f"{len(report_data['summary']['missing_headers'])} headers not configured"
            )

        if report_data['summary']['technologies_detected']:
            findings.append(
                f"Cloud Infrastructure Exposure - "
                f"{', '.join(report_data['summary']['technologies_detected'][:2])} detected"
            )

        if not findings:
            findings.append("No Critical/High Issues Found - Good security posture")

        return findings

    def _build_vulnerabilities_section(self, report_data: Dict[str, Any]) -> List:
        """Build vulnerabilities section with full details."""

        elements = []

        header_style = self.styles.get_style('SectionHeader')
        if header_style:
            elements.append(Paragraph("NUCLEI VULNERABILITIES", header_style))
            elements.append(Spacer(1, self.config.SPACING_SM))

        subheader_style = self.styles.get_style('SubsectionHeader')
        if subheader_style:
            elements.append(Paragraph("Vulnerabilities by Severity", subheader_style))
            elements.append(Spacer(1, self.config.SPACING_XS))

        risk_matrix = self.risk_calculator.generate_risk_matrix(report_data)
        risk_table = self.table_builder.create_risk_table(
            risk_matrix, report_data['summary']['vulnerability_by_severity']
        )
        if risk_table:
            elements.append(risk_table)
            elements.append(Spacer(1, self.config.SPACING_SM))

        # FIX BUG 3: 'low_vulns' is now reliably present in summary
        if report_data['summary']['low_vulns']:
            if subheader_style:
                elements.append(Paragraph("LOW SEVERITY FINDINGS", subheader_style))
                elements.append(Spacer(1, self.config.SPACING_XS))

            low_data = [['Vulnerability', 'Affected Host', 'Description', 'Recommendation']]
            for vuln in report_data['summary']['low_vulns'][:5]:
                details = self.vuln_processor.get_vuln_details(vuln)
                low_data.append([
                    TextUtils.safe_text(details['name'], 40),
                    TextUtils.safe_text(details['host'], 30),
                    TextUtils.safe_text(details['description'], 80),
                    TextUtils.safe_text(details['remediation'], 50)
                ])

            low_table = self.table_builder.create_table(
                low_data,
                col_widths=[2 * inch, 1.5 * inch, 3 * inch, 2 * inch],
                header_color=self.config.SEVERITY_LOW,
                font_size=8
            )
            if low_table:
                elements.append(low_table)
                elements.append(Spacer(1, self.config.SPACING_SM))

        info_vulns = [
            v for v in report_data['vulnerabilities']
            if v.get('info', {}).get('severity', '').lower() == 'info'
        ]
        if info_vulns:
            if subheader_style:
                elements.append(Paragraph("INFORMATIONAL FINDINGS", subheader_style))
                elements.append(Spacer(1, self.config.SPACING_XS))

            categories = defaultdict(list)
            for vuln in info_vulns[:20]:
                template_id = vuln.get('template-id', '')
                if 'waf-detect' in template_id:
                    categories['WAF Detection'].append(vuln)
                elif 'missing-security-headers' in template_id:
                    categories['Missing Headers'].append(vuln)
                elif 'spf' in template_id or 'dmarc' in template_id:
                    categories['DNS Records'].append(vuln)
                elif 'tech-detect' in template_id or 'wappalyzer' in template_id:
                    categories['Technology'].append(vuln)
                else:
                    categories['Other'].append(vuln)

            list_style = self.styles.get_style('ListItem')
            for category, vulns in categories.items():
                if list_style:
                    elements.append(Paragraph(category, list_style))
                    for vuln in vulns[:3]:
                        host = vuln.get('host', 'N/A')
                        elements.append(
                            Paragraph(
                                f"  - {vuln.get('info', {}).get('name', 'Unknown')} - {host}",
                                list_style
                            )
                        )
                    elements.append(Spacer(1, self.config.SPACING_XS))

        return elements

    def _build_assets_section(self, report_data: Dict[str, Any]) -> List:
        """Build assets overview section."""

        elements = []

        header_style = self.styles.get_style('SectionHeader')
        if header_style:
            elements.append(Paragraph("ASSET OVERVIEW", header_style))
            elements.append(Spacer(1, self.config.SPACING_SM))

        subheader_style = self.styles.get_style('SubsectionHeader')
        if subheader_style:
            elements.append(Paragraph("DNS Configuration Summary", subheader_style))
            elements.append(Spacer(1, self.config.SPACING_XS))

        dns_table = self.table_builder.create_dns_status_table(
            report_data['summary']['dns_records']
        )
        if dns_table:
            elements.append(dns_table)
            elements.append(Spacer(1, self.config.SPACING_SM))

        if report_data['live_hosts']:
            if subheader_style:
                elements.append(Paragraph("Live Hosts", subheader_style))
                elements.append(Spacer(1, self.config.SPACING_XS))

            hosts_data = [['URL', 'Status Code', 'Title', 'IP Address', 'Technology']]
            for host in report_data['live_hosts'][:self.config.MAX_HOSTS_PER_PAGE]:
                tech = (', '.join(host.get('tech', [])[:3])
                        if host.get('tech') else 'N/A')
                hosts_data.append([
                    TextUtils.safe_text(host.get('url', 'N/A'), 50),
                    str(host.get('status_code', 'N/A')),
                    TextUtils.safe_text((host.get('title', 'N/A') or 'N/A'), 40),
                    host.get('ip', 'N/A'),
                    TextUtils.safe_text(tech, 40)
                ])

            hosts_table = self.table_builder.create_table(
                hosts_data,
                col_widths=[2.5 * inch, 0.8 * inch, 2 * inch, 1.2 * inch, 1.5 * inch],
                header_color=self.config.COLOR_SUCCESS,
                font_size=8
            )
            if hosts_table:
                elements.append(hosts_table)

        return elements

    def _build_nmap_section(self, report_data: Dict[str, Any]) -> List:
        """Build Nmap scan results section."""

        elements = []

        header_style = self.styles.get_style('SectionHeader')
        if header_style:
            elements.append(Paragraph("NMAP PORT SCAN RESULTS", header_style))
            elements.append(Spacer(1, self.config.SPACING_SM))

        if report_data['nmap_results'] and report_data['summary']['open_ports']:
            ports_data = self.nmap_processor.get_ports_table(
                report_data['summary']['open_ports']
            )
            ports_table = self.table_builder.create_table(
                ports_data,
                col_widths=[1 * inch, 1 * inch, 0.5 * inch, 0.6 * inch,
                            1 * inch, 1.2 * inch, 0.6 * inch, 0.6 * inch],
                header_color=self.config.COLOR_WARNING,
                font_size=7
            )
            if ports_table:
                elements.append(ports_table)

            if report_data['summary']['services_detected']:
                elements.append(Spacer(1, self.config.SPACING_XS))
                normal_style = self.styles.get_style('ReportNormal')
                if normal_style:
                    services_text = (
                        f"<b>Detected Services:</b> "
                        f"{', '.join(report_data['summary']['services_detected'][:10])}"
                    )
                    elements.append(Paragraph(services_text, normal_style))
        else:
            normal_style = self.styles.get_style('ReportNormal')
            if normal_style:
                elements.append(Paragraph(
                    "Nmap port scan was not executed in this reconnaissance cycle. "
                    "Recommended for next assessment.",
                    normal_style
                ))

        return elements

    def _build_dns_ssl_section(self, report_data: Dict[str, Any]) -> List:
        """Build DNS and SSL configuration section."""

        elements = []

        header_style = self.styles.get_style('SectionHeader')
        if header_style:
            elements.append(Paragraph("DNS & SSL CONFIGURATION", header_style))
            elements.append(Spacer(1, self.config.SPACING_SM))

        subheader_style = self.styles.get_style('SubsectionHeader')
        if subheader_style:
            elements.append(Paragraph("SSL/TLS Configuration", subheader_style))
            elements.append(Spacer(1, self.config.SPACING_XS))

        ssl_data = self.dns_ssl_processor.get_ssl_status_table(
            report_data['summary']['ssl_info']
        )
        ssl_table = self.table_builder.create_table(
            ssl_data,
            col_widths=[1.5 * inch, 3.5 * inch, 1.5 * inch],
            header_color=self.config.COLOR_INFO,
            font_size=9
        )
        if ssl_table:
            elements.append(ssl_table)

        return elements

    def _build_recommendations_section(self, report_data: Dict[str, Any]) -> List:
        """Build security recommendations section."""

        elements = []

        header_style = self.styles.get_style('SectionHeader')
        if header_style:
            elements.append(Paragraph("SECURITY RECOMMENDATIONS", header_style))
            elements.append(Spacer(1, self.config.SPACING_SM))

        recommendations = self.recommendation_engine.generate_recommendations(report_data)

        subheader_style = self.styles.get_style('SubsectionHeader')
        list_style = self.styles.get_style('ListItem')

        for idx, rec in enumerate(recommendations, 1):
            if subheader_style:
                elements.append(
                    Paragraph(f"{idx}. {rec.get('title', 'Recommendation')}", subheader_style)
                )

            normal_style = self.styles.get_style('ReportNormal')
            if normal_style:
                elements.append(Paragraph(rec.get('description', ''), normal_style))
                elements.append(Paragraph(
                    f"<b>Priority:</b> {rec.get('priority', 'Medium')} | "
                    f"<b>Effort:</b> {rec.get('effort', 'Medium')}",
                    normal_style
                ))

            if subheader_style:
                elements.append(Paragraph("Recommended Actions:", subheader_style))

            if list_style:
                for action in rec.get('actions', [])[:5]:
                    elements.append(Paragraph(f"- {action}", list_style))

            elements.append(Spacer(1, self.config.SPACING_SM))

        if recommendations:
            if subheader_style:
                elements.append(Paragraph("RECOMMENDED ACTION PLAN", subheader_style))

            action_plan = [
                "Week 1: Implement Security Headers (CSP, HSTS, X-Frame, X-Content-Type-Options)",
                "Week 2: Disable TLS 1.0/1.1, Update Cipher Suites",
                "Week 3: Review & Document Public Information Exposure",
                "Week 4: Conduct Follow-up Assessment"
            ]

            if list_style:
                for action in action_plan:
                    elements.append(Paragraph(f"- {action}", list_style))

        return elements

    def _build_footer(self, report_data: Dict[str, Any]) -> List:
        """Build report footer."""

        elements = []
        elements.append(PageBreak())
        elements.append(Spacer(1, self.config.SPACING_LG))

        footer_style = self.styles.get_style('ReportFooter')
        if footer_style:
            footer_text = (
                f"<b>Generated by:</b> Recon Dashboard v4.0<br/>"
                f"<b>Generation Timestamp:</b> {datetime.now().strftime('%Y-%m-%d %H:%M:%S UTC')}<br/>"
                f"<b>Report Classification:</b> CONFIDENTIAL<br/>"
                f"<b>Distribution:</b> Internal Security Team Only"
            )
            elements.append(Paragraph(footer_text, footer_style))

        disclaimer_style = self.styles.get_style('Disclaimer')
        if disclaimer_style:
            elements.append(Spacer(1, self.config.SPACING_XS))
            elements.append(Paragraph(
                "DISCLAIMER: This report is for authorized security assessment purposes only. "
                "Do not distribute without explicit permission from the security team.",
                disclaimer_style
            ))

        return elements

    def generate_json(self, report_data: Dict[str, Any]) -> str:
        """Generate JSON report."""
        try:
            self.logger.log_info("Generating JSON report...")
            return json.dumps(report_data, indent=2, default=str)
        except Exception as e:
            self.logger.log_exception(f"JSON generation failed: {e}")
            raise

    def generate_excel(self, report_data: Dict[str, Any]) -> bytes:
        """Generate Excel report.

        FIX BUG 10: header_alignment is now applied to header cells BEFORE the
        generic wrap alignment so it is not overwritten.
        """
        try:
            self.logger.log_info("Generating Excel report...")

            if not OPENPYXL_AVAILABLE:
                raise ImportError("OpenPyXL not available. Install with: pip install openpyxl")

            workbook = Workbook()

            # FIX BUG 2/8: Using XLFont / XLAlignment (aliased imports) — no clash with RLColor
            header_font = XLFont(bold=True, color="FFFFFF", size=11)
            header_fill = PatternFill(start_color="3498db", end_color="3498db",
                                      fill_type="solid")
            header_alignment = XLAlignment(horizontal="center", vertical="center",
                                           wrap_text=True)
            body_alignment = XLAlignment(wrap_text=True)

            summary_sheet = workbook.active
            summary_sheet.title = "Summary"

            summary_data = [
                ["Metric", "Value"],
                ["Target", report_data['scan_info']['target']],
                ["Scan ID", report_data['scan_info']['id']],
                ["Status", report_data['scan_info']['status']],
                ["Overall Risk", report_data['summary']['overall_risk']],
                ["Security Score", f"{report_data['summary']['security_score']}/100"],
                ["Subdomains", report_data['summary']['total_subdomains']],
                ["Live Hosts", report_data['summary']['total_live_hosts']],
                ["Vulnerabilities", report_data['summary']['total_vulnerabilities']],
                ["Critical", report_data['summary']['vulnerability_by_severity']['critical']],
                ["High", report_data['summary']['vulnerability_by_severity']['high']],
                ["Medium", report_data['summary']['vulnerability_by_severity']['medium']],
                ["Low", report_data['summary']['vulnerability_by_severity']['low']],
                ["Info", report_data['summary']['vulnerability_by_severity']['info']],
            ]

            for row_idx, row_data in enumerate(summary_data, 1):
                for col_idx, value in enumerate(row_data, 1):
                    cell = summary_sheet.cell(row=row_idx, column=col_idx, value=value)
                    if row_idx == 1:
                        # FIX BUG 10: Apply header formatting first, including alignment,
                        # so the subsequent body_alignment assignment is skipped.
                        cell.font = header_font
                        cell.fill = header_fill
                        cell.alignment = header_alignment
                    else:
                        cell.alignment = body_alignment

            buffer = io.BytesIO()
            workbook.save(buffer)
            buffer.seek(0)

            self.logger.log_info("Excel generated successfully")
            return buffer.getvalue()

        except Exception as e:
            self.logger.log_exception(f"Excel generation failed: {e}")
            raise

    def generate_docx(self, report_data: Dict[str, Any]) -> bytes:
        """Generate Word document report."""
        try:
            self.logger.log_info("Generating Word report...")

            if not DOCX_AVAILABLE:
                raise ImportError("Python-Docx not available. Install with: pip install python-docx")

            doc = Document()

            title = doc.add_heading('Security Reconnaissance Report', 0)
            title.alignment = WD_ALIGN_PARAGRAPH.CENTER

            doc.add_heading('Scan Information', level=1)
            info_table = doc.add_table(rows=6, cols=2)
            info_table.style = 'Table Grid'

            info_data = [
                ('Target', report_data['scan_info']['target']),
                ('Scan ID', report_data['scan_info']['id']),
                ('Status', report_data['scan_info']['status']),
                ('Overall Risk', report_data['summary']['overall_risk']),
                ('Started', report_data['scan_info']['started_at']),
                ('Completed', report_data['scan_info'].get('completed_at', 'N/A'))
            ]

            for idx, (label, value) in enumerate(info_data):
                cell_label = info_table.cell(idx, 0)
                cell_value = info_table.cell(idx, 1)
                cell_label.text = label
                cell_value.text = str(value)
                cell_label.paragraphs[0].runs[0].bold = True

            doc.add_paragraph()

            doc.add_heading('Executive Summary', level=1)
            sev = report_data['summary']['vulnerability_by_severity']
            doc.add_paragraph(
                f"Total Vulnerabilities: {report_data['summary']['total_vulnerabilities']}"
            )
            doc.add_paragraph(f"Critical: {sev['critical']}")
            doc.add_paragraph(f"High: {sev['high']}")
            doc.add_paragraph(f"Medium: {sev['medium']}")
            doc.add_paragraph(f"Low: {sev['low']}")
            doc.add_paragraph(f"Info: {sev['info']}")

            buffer = io.BytesIO()
            doc.save(buffer)
            buffer.seek(0)

            self.logger.log_info("Word document generated successfully")
            return buffer.getvalue()

        except Exception as e:
            self.logger.log_exception(f"Word generation failed: {e}")
            raise

    def generate_csv(self, report_data: Dict[str, Any]) -> str:
        """Generate CSV report."""
        try:
            self.logger.log_info("Generating CSV report...")

            buffer = io.StringIO()
            writer = csv.writer(buffer)

            writer.writerow(['Severity', 'Vulnerability', 'Host', 'Template', 'Description'])

            for vuln in report_data.get('vulnerabilities', []):
                writer.writerow([
                    vuln.get('info', {}).get('severity', 'info'),
                    vuln.get('info', {}).get('name', 'Unknown'),
                    vuln.get('host', 'N/A'),
                    vuln.get('template-id', 'N/A'),
                    vuln.get('info', {}).get('description', 'N/A')[:200]
                ])

            return buffer.getvalue()

        except Exception as e:
            self.logger.log_exception(f"CSV generation failed: {e}")
            raise

    def generate_xml(self, report_data: Dict[str, Any]) -> str:
        """Generate XML report."""
        try:
            self.logger.log_info("Generating XML report...")

            root = ET.Element('SecurityReport')

            scan_info_elem = ET.SubElement(root, 'ScanInfo')
            ET.SubElement(scan_info_elem, 'Target').text = report_data['scan_info']['target']
            ET.SubElement(scan_info_elem, 'ScanID').text = report_data['scan_info']['id']
            ET.SubElement(scan_info_elem, 'Status').text = report_data['scan_info']['status']

            summary_elem = ET.SubElement(root, 'Summary')
            ET.SubElement(summary_elem, 'TotalVulnerabilities').text = str(
                report_data['summary']['total_vulnerabilities']
            )
            ET.SubElement(summary_elem, 'Critical').text = str(
                report_data['summary']['vulnerability_by_severity']['critical']
            )
            ET.SubElement(summary_elem, 'High').text = str(
                report_data['summary']['vulnerability_by_severity']['high']
            )

            vulns_elem = ET.SubElement(root, 'Vulnerabilities')
            for vuln in report_data.get('vulnerabilities', [])[:100]:
                vuln_elem = ET.SubElement(vulns_elem, 'Vulnerability')
                ET.SubElement(vuln_elem, 'Severity').text = (
                    vuln.get('info', {}).get('severity', 'info')
                )
                ET.SubElement(vuln_elem, 'Name').text = (
                    vuln.get('info', {}).get('name', 'Unknown')
                )
                ET.SubElement(vuln_elem, 'Host').text = vuln.get('host', 'N/A')

            return ET.tostring(root, encoding='unicode')

        except Exception as e:
            self.logger.log_exception(f"XML generation failed: {e}")
            raise

    def generate_html(self, report_data: Dict[str, Any]) -> str:
        """Generate HTML report.

        FIX BUG 4: Renamed local variable from `html` to `html_content` to
        avoid shadowing the module-level `import html as html_module`.
        """
        try:
            self.logger.log_info("Generating HTML report...")

            # FIX BUG 4: was `html = f"""..."""` which shadowed the html module alias
            html_content = f"""<!DOCTYPE html>
<html>
<head>
    <title>Security Report - {report_data['scan_info']['target']}</title>
    <style>
        body {{ font-family: Arial, sans-serif; margin: 40px; }}
        h1 {{ color: #2c3e50; }}
        table {{ border-collapse: collapse; width: 100%; }}
        th, td {{ border: 1px solid #ddd; padding: 8px; text-align: left; }}
        th {{ background-color: #3498db; color: white; }}
    </style>
</head>
<body>
    <h1>Security Reconnaissance Report</h1>
    <h2>Target: {report_data['scan_info']['target']}</h2>
    <h2>Scan ID: {report_data['scan_info']['id']}</h2>
    <h2>Total Vulnerabilities: {report_data['summary']['total_vulnerabilities']}</h2>
</body>
</html>"""

            return html_content

        except Exception as e:
            self.logger.log_exception(f"HTML generation failed: {e}")
            raise


